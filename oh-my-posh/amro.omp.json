{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "template": "\uf508 {{ .UserName }} on",
          "foreground": "#45F1C2",
          "type": "session"
        },
        {
          "properties": {
            "folder_separator_icon": "/",
            "style": "full"
          },
          "style": "plain",
          "template": " \uf07b {{ .Path }} ",
          "foreground": "#0CA0D8",
          "type": "path"
        },
        {
          "properties": {
            "fetch_stash_count": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "{{ .UpstreamIcon }}{{ .HEAD }}{{ if gt .StashCount 0 }} \uf692 {{ .StashCount }}{{ end }} ",
          "foreground": "#14A5AE",
          "powerline_symbol": "\ue0b0",
          "type": "git"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "template": "\ue3bf ",
          "foreground": "#cd5e42",
          "type": "root"
        },
        {
          "style": "plain",
          "template": "# ",
          "foreground": "#CD4277",
          "type": "text"
        }
      ],
      "newline": true
    }
  ],
  "pwd": "osc9;9",
  "version": 3
}
